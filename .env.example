# ============================================================
# App
# ============================================================

# Canonical site URL — used for metadata (canonicals, Open Graph),
# sitemap.xml, and robots.txt. Defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# ============================================================
# Email (contact form delivery)
# ============================================================
# All optional — when RESEND_API_KEY is unset, messages are
# validated and logged server-side instead of emailed.

# Get a key at https://resend.com
RESEND_API_KEY=

# Where messages land; defaults to nickhowell6425@gmail.com
CONTACT_TO_EMAIL=

# Must be a verified sender on your Resend account;
# defaults to onboarding@resend.dev
CONTACT_FROM_EMAIL=
